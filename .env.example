# --- AI layer ---
# Required for live regime calls (paper trading still works without it; the
# rule engine just falls back to a no-trade "chop" regime).
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional free pre-filter. Leave empty to skip the Groq step entirely.
GROQ_API_KEY=

# Optional Grok (xAI) X-sentiment layer. Leave empty to skip it entirely —
# the system runs fine on the Anthropic key alone.
XAI_API_KEY=
# ~$0.14/call at 5 search sources (5 × $0.025 + tokens) -> ≈7 calls/day fit in $1.
GROK_DAILY_BUDGET_USD=1.00
# Verify the current model name in the xAI docs (https://docs.x.ai).
GROK_MODEL=grok-4-3

# Hard daily cap on Anthropic spend (USD).
AI_DAILY_BUDGET_USD=0.50

# Model + pricing constants used for spend estimation (USD per million tokens).
AI_MODEL=claude-sonnet-4-6
AI_PRICE_INPUT_MTOK=3.0
AI_PRICE_OUTPUT_MTOK=15.0

# --- execution ---
# 'paper' (default, pure simulation) or 'testnet' (real orders on Binance Spot
# TESTNET — fake funds). The testnet base URL is hard-coded in the executor;
# there is no way to point it at mainnet, and no live executor exists.
EXECUTOR=paper
# Testnet keys from https://testnet.binance.vision (do not work on mainnet).
BINANCE_TESTNET_API_KEY=
BINANCE_TESTNET_API_SECRET=

# --- trading (all optional, defaults shown) ---
PAIRS=BTCUSDT,ETHUSDT
CYCLE_MINUTES=15
AI_CADENCE_HOURS=4
START_BALANCE=1000
RISK_PER_TRADE=0.01
STOP_ATR_MULT=1.5
TP_ATR_MULT=2.5
MAX_POSITIONS=2
MAX_NOTIONAL_PCT=0.25
DAILY_DRAWDOWN_HALT=0.03
COOLDOWN_HOURS=4
SLIPPAGE=0.0005
TAKER_FEE=0.001

# Set to 1 to run fully offline with synthetic data and a canned AI regime.
# TRADEPILOT_MOCK=1
