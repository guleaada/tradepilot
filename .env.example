# --- AI layer ---
# Required for live regime calls (paper trading still works without it; the
# rule engine just falls back to a no-trade "chop" regime).
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional free pre-filter. Leave empty to skip the Groq step entirely.
GROQ_API_KEY=

# Optional Grok (xAI) X-sentiment layer. Leave empty to skip it entirely —
# the system runs fine on the Anthropic key alone.
XAI_API_KEY=
# ~$0.14/call at 5 search sources (5 × $0.025 + tokens) -> ≈7 calls/day fit in $1.
GROK_DAILY_BUDGET_USD=1.00
# Verify the current model name in the xAI docs (https://docs.x.ai).
GROK_MODEL=grok-4-3

# Hard daily cap on Anthropic spend (USD).
AI_DAILY_BUDGET_USD=0.50

# Model + pricing constants used for spend estimation (USD per million tokens).
AI_MODEL=claude-sonnet-4-6
AI_PRICE_INPUT_MTOK=3.0
AI_PRICE_OUTPUT_MTOK=15.0

# --- execution ---
# 'paper' (default, pure simulation) or 'testnet' (real orders on Binance Spot
# TESTNET — fake funds). The testnet base URL is hard-coded in the executor;
# there is no way to point it at mainnet, and no live executor exists.
EXECUTOR=paper
# Testnet keys from https://testnet.binance.vision (do not work on mainnet).
BINANCE_TESTNET_API_KEY=
BINANCE_TESTNET_API_SECRET=

# --- trading (all optional, defaults shown) ---
PAIRS=BTCUSDT,ETHUSDT,SOLUSDT,BNBUSDT,XRPUSDT
# Pairs with 24h quote volume below this are excluded for the run.
LIQUIDITY_MIN_VOLUME_24H=50000000
CYCLE_MINUTES=15
AI_CADENCE_HOURS=4
START_BALANCE=1000
RISK_PER_TRADE=0.01
STOP_ATR_MULT=1.5
TP_ATR_MULT=2.5
MAX_POSITIONS=2
MAX_NOTIONAL_PCT=0.25
DAILY_DRAWDOWN_HALT=0.03
COOLDOWN_HOURS=4
SLIPPAGE=0.0005
TAKER_FEE=0.001

# --- entry filters (set any to false to restore the original behavior) ---
# Require current 1h volume >= 110% of its 20-period average.
VOLUME_FILTER_ENABLED=true
VOLUME_MIN_RATIO=1.1
# Require price above the daily EMA(50).
MTF_DAILY_FILTER_ENABLED=true
# ATR-percentile RSI zones: calm tape [48,65], volatile tape [42,75].
DYNAMIC_RSI_ENABLED=true
# Block entries correlated >= 0.85 with an already-open pair (20-period 1h returns).
CORRELATION_FILTER_ENABLED=true
CORRELATION_MAX=0.85
# Opt-in: block new entries Fri 20:00 UTC -> Sun 20:00 UTC.
WEEKEND_FILTER_ENABLED=false

# --- trailing stop + partial exits ---
TRAILING_STOP_ENABLED=true
# Move stop to breakeven at +1.5R.
BREAKEVEN_R=1.5
# Close 50% at +2.0R; remainder targets 4.0R.
PARTIAL_EXIT_R=2.0
PARTIAL_EXIT_FRACTION=0.5
EXTENDED_TP_R=4.0

# --- regime-dependent risk sizing ---
# Bullish regime with confidence >= 80 risks 1.5% (notional cap 30%).
REGIME_RISK_SCALING_ENABLED=true
RISK_PCT_HIGH_CONF=0.015
MAX_NOTIONAL_HIGH_CONF=0.30
HIGH_CONF_THRESHOLD=80

# --- emergency price-action exit ---
# Close any position trading >= 5% below entry, regardless of stop/regime.
EMERGENCY_EXIT_ENABLED=true
EMERGENCY_EXIT_DROP_PCT=0.05

# --- volatility targeting ---
# Scale new position sizes down when realized portfolio vol exceeds 40% annualized.
VOL_TARGETING_ENABLED=true
VOL_TARGET_ANNUALIZED=0.40

# --- Telegram alerts (optional; alerts are a silent no-op when unset) ---
# Create a bot with @BotFather, then put its token here.
TELEGRAM_BOT_TOKEN=
# Your chat id (message the bot, then check api.telegram.org/bot<token>/getUpdates).
TELEGRAM_CHAT_ID=

# Set to 1 to run fully offline with synthetic data and a canned AI regime.
# TRADEPILOT_MOCK=1
